// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Airport {
  iata         String   @id
  name         String
  city         String
  country      String
  lat          Decimal
  long         Decimal
  links        Int
  searchString String
  createdAt    DateTime @default(now())
}
